DATA_SOURCE=google_sheets
CSV_PATH=data/participants.csv

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_digit_app_password
FROM_EMAIL=your_email@gmail.com
DRY_RUN=false
# Canli Form dongusu: Google Sheet'i periyodik tara (yalnizca DATA_SOURCE=google_sheets)
LIVE_LOOP=true
LIVE_POLL_SECONDS=20
ENABLE_SMTP_SEND=true
ENABLE_STATUS_UPDATE=true
MAX_SEND_COUNT=0
SMTP_BATCH_SIZE=50
SMTP_BATCH_SLEEP_SECONDS=10
# Gemini kota: istekler arasi saniye (varsayilan 3)
GEMINI_REQUEST_DELAY_SECONDS=3
# Canlida false tutun; API anahtari olmadan yerel test icin true
GEMINI_USE_MOCK=false
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
QR_CODE_IMAGE_PATH=
ARCHIVE_SENT_PDFS=true
ALLOW_MISSING_TEMPLATE_FALLBACK=true

# Google Form yanitlari: [Zaman Damgasi, Adiniz, Soyadiniz, E-posta Adresiniz, Okulunuz, Bolumunuz, Durum]
# DATA_SOURCE=google_sheets oldugunda gerekli:
GOOGLE_SERVICE_ACCOUNT_JSON=C:/path/to/service-account.json
GOOGLE_SHEET_NAME=Google Form Responses
GOOGLE_WORKSHEET_NAME=Form Responses 1
